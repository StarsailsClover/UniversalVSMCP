{
  "$schema": "https://raw.githubusercontent.com/docker/mcp-community-registry/main/docs/reference/server-json/draft/server.schema.json",
  "name": "universal-vsmcp",
  "version": "26.0.0",
  "description": "MCP Server for Visual Studio 2026/2022 automation via DTE/OM. Supports both stdio and HTTP/SSE transports for maximum compatibility.",
  "author": {
    "name": "StarsailsClover",
    "email": "contact@starsailsclover.dev",
    "url": "https://github.com/StarsailsClover"
  },
  "license": "MIT",
  "homepage": "https://github.com/StarsailsClover/UniversalVSMCP",
  "repository": {
    "type": "git",
    "url": "https://github.com/StarsailsClover/UniversalVSMCP.git"
  },
  "keywords": [
    "visual-studio",
    "mcp",
    "ide",
    "automation",
    "dotnet",
    "csharp",
    "dte",
    "envdte",
    "vs2026",
    "vs2022",
    "ai-agent",
    "sse",
    "http"
  ],
  "category": "development",
  "tags": ["visual-studio", "mcp", "automation", "dotnet", "sse", "http"],
  "transports": ["stdio", "sse", "http"],
  "mcpServers": {
    "universal-vsmcp-stdio": {
      "name": "Universal VS MCP (stdio)",
      "command": "dotnet",
      "args": [
        "tool",
        "run",
        "--global",
        "universal-vsmcp",
        "--",
        "--stdio"
      ],
      "transport": "stdio",
      "env": {
        "VS_AUTO_DETECT": "true"
      },
      "description": "Primary stdio transport for Claude/Cursor. Best for AI agents."
    },
    "universal-vsmcp-sse": {
      "name": "Universal VS MCP (SSE)",
      "url": "http://localhost:5000/sse",
      "transport": "sse",
      "description": "HTTP/SSE transport for Visual Studio 2026 MCP Server Manager. Start server with 'universal-vsmcp --http 5000'"
    },
    "universal-vsmcp-local-stdio": {
      "name": "Universal VS MCP (Local stdio)",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}",
        "--",
        "--stdio"
      ],
      "transport": "stdio",
      "env": {
        "VS_AUTO_DETECT": "true"
      },
      "description": "Local development with stdio transport"
    }
  },
  "installation": {
    "dotnetTool": {
      "command": "dotnet tool install -g UniversalVSMCP",
      "package": "UniversalVSMCP"
    }
  },
  "configuration": {
    "stdio": {
      "command": "universal-vsmcp",
      "args": ["--stdio"],
      "description": "Standard input/output transport"
    },
    "http": {
      "command": "universal-vsmcp",
      "args": ["--http", "5000"],
      "url": "http://localhost:5000/sse",
      "description": "HTTP/SSE transport on localhost"
    },
    "hybrid": {
      "command": "universal-vsmcp",
      "args": ["--hybrid", "5000"],
      "description": "Both stdio and HTTP transports"
    }
  },
  "requirements": {
    "dotnet": ">=8.0.0",
    "visualStudio": {
      "vs2026": ">=18.0",
      "vs2022": ">=17.14"
    },
    "os": ["windows"]
  },
  "tools": [
    {
      "name": "get_solution_projects",
      "description": "Get all projects in the current VS solution",
      "category": "solution"
    },
    {
      "name": "get_solution_path",
      "description": "Get the path of the currently open solution",
      "category": "solution"
    },
    {
      "name": "get_solution_name",
      "description": "Get the name of the current solution",
      "category": "solution"
    },
    {
      "name": "open_solution",
      "description": "Open a .sln file in Visual Studio",
      "category": "solution"
    },
    {
      "name": "close_solution",
      "description": "Close the current solution",
      "category": "solution"
    },
    {
      "name": "create_solution",
      "description": "Create a new solution/workspace",
      "category": "solution"
    },
    {
      "name": "get_project_files",
