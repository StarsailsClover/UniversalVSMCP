    {
      "name": "replace_in_file",
      "description": "Replace text in file",
      "category": "file"
    },
    {
      "name": "get_file_info",
      "description": "Get file information",
      "category": "file"
    },
    {
      "name": "build_solution",
      "description": "Build solution",
