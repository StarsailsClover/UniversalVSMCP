{
  "$schema": "https://github.com/docker/mcp-community-registry/blob/main/docs/reference/server-json/draft/server.schema.json",
  "name": "universal-vsmcp",
  "version": "1.0.0",
  "description": "MCP Server for Visual Studio 2026/2022 automation via DTE/OM. Enables AI agents to control VS through file operations, project management, builds, and debugging.",
  "author": {
    "name": "StarsailsClover",
    "email": "contact@starsailsclover.dev",
    "url": "https://github.com/StarsailsClover"
  },
  "license": "MIT",
  "homepage": "https://github.com/StarsailsClover/UniversalVSMCP",
  "repository": {
    "type": "git",
    "url": "https://github.com/StarsailsClover/UniversalVSMCP.git"
  },
  "keywords": [
    "visual-studio",
    "mcp",
    "ide",
    "automation",
    "dotnet",
    "csharp",
    "dte",
    "envdte",
    "vs2026",
    "vs2022",
    "ai-agent"
  ],
  "category": "development",
  "tags": ["visual-studio", "mcp", "automation", "dotnet"],
  "mcpServers": {
    "universal-vsmcp": {
      "command": "dotnet",
      "args": [
        "tool",
        "run",
        "--global",
        "universal-vsmcp",
        "--",
        "--stdio"
      ],
      "transport": "stdio",
      "env": {
        "VS_AUTO_DETECT": "true",
        "DOTNET_ENVIRONMENT": "Production"
      }
    },
    "universal-vsmcp-local": {
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "C:\\path\\to\\UniversalVSMCP\\src\\UniversalVSMCP\\UniversalVSMCP.csproj",
        "--",
        "--stdio"
      ],
      "transport": "stdio",
      "env": {
        "VS_AUTO_DETECT": "true"
      }
    }
  },
  "tools": [
    {
      "name": "get_solution_projects",
      "description": "Get all projects in the current VS solution with their names, types, and paths",
      "category": "solution",
      "inputSchema": {
        "type": "object",
        "properties": {}
      }
    },
    {
      "name": "get_solution_path",
      "description": "Get the full path of the currently open solution file (.sln)",
      "category": "solution",
      "inputSchema": {
        "type": "object",
        "properties": {}
      }
    },
    {
      "name": "get_solution_name",
      "description": "Get the name of the currently open solution",
      "category": "solution",
      "inputSchema": {
        "type": "object",
        "properties": {}
      }
    },
    {
      "name": "open_solution",
      "description": "Open a .sln solution file in Visual Studio",
      "category": "solution",
      "inputSchema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "description": "Full path to .sln file"
          }
        },
        "required": ["path"]
      }
    },
    {
      "name": "close_solution",
      "description": "Close the currently open solution",
      "category": "solution",
      "inputSchema": {
        "type": "object",
        "properties": {}
      }
    },
    {
      "name": "open_file",
      "description": "Open a file in Visual Studio editor at optional line number",
      "category": "file",
      "inputSchema": {
        "type": "object",
        "properties": {
          "file_path": {
            "type": "string",
            "description": "Full path to file"
          },
          "line": {
            "type": "integer",
            "description": "Line number to navigate to"
          }
        },
        "required": ["file_path"]
      }
    },
    {
      "name": "read_file",
      "description": "Read content of a text file (up to maxLines lines)",
      "category": "file",
      "inputSchema": {
        "type": "object",
        "properties": {
          "file_path": {
            "type": "string",
            "description": "Full path to file"
          },
          "max_lines": {
            "type": "integer",
            "description": "Maximum lines to read (default 500)"
          },
          "start_line": {
            "type": "integer",
            "description": "Starting line number (default 1)"
          }
        },
        "required": ["file_path"]
      }
    },
    {
      "name": "write_file",
      "description": "Write content to a file with optional backup",
      "category": "file",
      "inputSchema": {
        "type": "object",
        "properties": {
          "file_path": {
            "type": "string",
            "description": "Full path to file"
          },
          "content": {
            "type": "string",
            "description": "Content to write"
          },
          "create_backup": {
            "type": "boolean",
            "description": "Create .bak backup (default true)"
          }
        },
        "required": ["file_path", "content"]
      }
    },
    {
      "name": "build_solution",
      "description": "Build the current solution with specified configuration",
      "category": "build",
      "inputSchema": {
        "type": "object",
        "properties": {
          "configuration": {
            "type": "string",
            "description": "Build config: Debug or Release (default Debug)"
          },
          "platform": {
            "type": "string",
            "description": "Build platform (default Any CPU)"
          }
        }
      }
    },
    {
      "name": "build_project",
      "description": "Build a specific project in the solution",
      "category": "build",
      "inputSchema": {
        "type": "object",
        "properties": {
          "project_name": {
            "type": "string",
            "description": "Name of the project"
          },
          "configuration": {
            "type": "string",
            "description": "Build config (default Debug)"
          }
        },
        "required": ["project_name"]
      }
    },
    {
      "name": "start_debugging",
      "description": "Start debugging the startup project (F5)",
      "category": "debug",
      "inputSchema": {
        "type": "object",
        "properties": {}
      }
    },
    {
      "name": "stop_debugging",
      "description": "Stop the current debugging session (Shift+F5)",
      "category": "debug",
      "inputSchema": {
        "type": "object",
        "properties": {}
      }
    },
    {
      "name": "toggle_breakpoint",
      "description": "Toggle a breakpoint at specified file and line",
      "category": "debug",
      "inputSchema": {
        "type": "object",
        "properties": {
          "file_path": {
            "type": "string",
            "description": "File path"
          },
          "line": {
            "type": "integer",
            "description": "Line number"
          }
        },
        "required": ["file_path", "line"]
      }
    }
  ],
  "requirements": {
    "dotnet": ">=8.0.0",
    "visual_studio": {
      "vs2026": "18.0",
      "vs2022": "17.14+"
    },
    "os": "Windows 10+"
  },
  "installation": {
    "global_tool": {
      "command": "dotnet tool install -g UniversalVSMCP",
      "description": "Install as global .NET tool"
    },
    "local_run": {
      "command": "dotnet run --project UniversalVSMCP.csproj -- --stdio",
      "description": "Run directly from source"
    },
    "nuget": {
      "package": "https://www.nuget.org/packages/UniversalVSMCP/",
      "description": "Install via NuGet (future)"
    }
  },
  "configuration": {
    "vs2026_gui": {
      "steps": [
        "1. Open Visual Studio 2026",
        "2. Go to Tools -> Options -> Environment -> Extensions",
        "3. In MCP Server List, click Add",
        "4. Enter Name: 'universal-vsmcp'",
        "5. Enter Command: 'dotnet'",
        "6. Enter Args: 'tool run --global universal-vsmcp -- --stdio'",
        "7. Save and restart VS"
      ]
    },
    "claude_desktop": {
      "config_path": "%APPDATA%\\Claude\\claude_desktop_config.json",
      "config": {
        "mcpServers": {
          "vsmcp": {
            "command": "dotnet",
            "args": ["tool", "run", "--global", "universal-vsmcp", "--", "--stdio"],
            "env": {
              "VS_AUTO_DETECT": "true"
            }
          }
        }
      }
    }
  },
  "registry": {
    "url": "https://github.com/StarsailsClover/UniversalVSMCP",
    "category": "ide-tools",
    "verified": false
  }
}
