{
  "$schema": "https://github.com/docker/mcp-community-registry/blob/main/docs/reference/server-json/draft/server.schema.json",
  "name": "universal-vsmcp",
  "version": "26.0.0",
  "description": "MCP Server for Visual Studio 2026/2022 automation via DTE/OM. Enables AI agents to control VS through file operations, project management, builds, and debugging.",
  "author": {
    "name": "StarsailsClover",
    "email": "contact@starsailsclover.dev",
    "url": "https://github.com/StarsailsClover"
  },
  "license": "MIT",
  "homepage": "https://github.com/StarsailsClover/UniversalVSMCP",
  "repository": {
    "type": "git",
    "url": "https://github.com/StarsailsClover/UniversalVSMCP.git"
  },
  "keywords": [
    "visual-studio",
    "mcp",
    "ide",
    "automation",
    "dotnet",
    "csharp",
    "dte",
    "envdte",
    "vs2026",
    "vs2022",
    "ai-agent"
  ],
  "category": "development",
  "tags": ["visual-studio", "mcp", "automation", "dotnet"],
  "mcpServers": {
    "universal-vsmcp": {
      "command": "dotnet",
      "args": [
        "tool",
        "run",
        "--global",
        "universal-vsmcp",
        "--",
        "--stdio"
      ],
      "transport": "stdio",
      "env": {
        "VS_AUTO_DETECT": "true"
      }
    },
    "universal-vsmcp-local": {
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}",
        "--",
        "--stdio"
      ],
      "transport": "stdio",
      "env": {
        "VS_AUTO_DETECT": "true"
      }
    },
    "universal-vsmcp-localhost": {
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "C:\\path\\to\\UniversalVSMCP\\src\\UniversalVSMCP\\UniversalVSMCP.csproj",
        "--",
        "--stdio"
      ],
      "transport": "stdio",
      "url": "http://localhost:6277/sse",
      "env": {
        "VS_AUTO_DETECT": "true"
      }
    }
  },
  "tools": [
    {
      "name": "get_solution_projects",
      "description": "Get all projects in the current VS solution",
      "category": "solution"
    },
    {
      "name": "get_solution_path",
      "description": "Get the path of the currently open solution",
      "category": "solution"
    },
    {
      "name": "get_solution_name",
      "description": "Get the name of the currently open solution",
      "category": "solution"
    },
    {
      "name": "open_solution",
      "description": "Open a .sln file in Visual Studio",
      "category": "solution"
    },
    {
      "name": "close_solution",
      "description": "Close the current solution",
      "category": "solution"
    },
    {
      "name": "create_solution",
      "description": "Create a new solution (workspace) at specified path",
      "category": "solution"
    },
    {
      "name": "get_project_files",
      "description": "Get files in a specific project",
      "category": "project"
    },
    {
      "name": "get_startup_projects",
      "description": "Get startup project(s)",
      "category": "project"
    },
    {
      "name": "add_file_to_project",
      "description": "Add file to project",
      "category": "project"
    },
    {
      "name": "set_startup_project",
      "description": "Set startup project",
      "category": "project"
    },
    {
      "name": "get_project_properties",
      "description": "Get project properties",
      "category": "project"
    },
    {
      "name": "open_file",
      "description": "Open file in VS editor",
      "category": "file"
    },
    {
      "name": "read_file",
      "description": "Read file content",
      "category": "file"
    },
    {
      "name": "write_file",
      "description": "Write content to file",
      "category": "file"
    },
    {
      "name": "replace_in_file",
      "description": "Replace text in file",
      "category": "file"
    },
    {
      "name": "get_file_info",
      "description": "Get file information",
      "category": "file"
    },
    {
      "name": "build_solution",
      "description": "Build solution",
      "category": "build"
    },
    {
      "name": "rebuild_solution",
      "description": "Rebuild solution",
      "category": "build"
    },
    {
      "name": "clean_solution",
      "description": "Clean solution",
      "category": "build"
    },
    {
      "name": "build_project",
      "description": "Build specific project",
      "category": "build"
    },
    {
      "name": "get_build_errors",
      "description": "Get build errors",
      "category": "build"
    },
    {
      "name": "get_build_configurations",
      "description": "Get available build configurations",
      "category": "build"
    },
    {
      "name": "start_debugging",
      "description": "Start debugging (F5)",
      "category": "debug"
    },
    {
      "name": "stop_debugging",
      "description": "Stop debugging (Shift+F5)",
      "category": "debug"
    },
    {
      "name": "toggle_breakpoint",
      "description": "Navigate to line for breakpoint",
      "category": "debug"
    },
    {
      "name": "continue_execution",
      "description": "Continue from breakpoint (F5)",
      "category": "debug"
    },
    {
      "name": "step_over",
      "description": "Step over (F10)",
      "category": "debug"
    },
    {
      "name": "step_into",
      "description": "Step into (F11)",
      "category": "debug"
    },
    {
      "name": "step_out",
      "description": "Step out (Shift+F11)",
      "category": "debug"
    },
    {
      "name": "get_debug_state",
      "description": "Get current debug state",
      "category": "debug"
    }
  ],
  "requirements": {
    "dotnet": ">=8.0.0",
    "visual_studio": {
      "vs2026": "18.0",
      "vs2022": "17.14+"
    },
    "os": "Windows 10+"
  },
  "installation": {
    "nuget": {
      "package_id": "UniversalVSMCP",
      "version": "1.0.0",
      "command": "dotnet tool install -g UniversalVSMCP",
      "url": "https://www.nuget.org/packages/UniversalVSMCP/"
    },
    "source": {
      "command": "dotnet run --project UniversalVSMCP.csproj -- --stdio",
      "url": "https://github.com/StarsailsClover/UniversalVSMCP"
    }
  },
  "configuration": {
    "user_level": {
      "path_windows": "%APPDATA%\\VisualStudio\\18.0\\UserSettings.json",
      "description": "User-level MCP configuration"
    },
    "solution_level": {
      "path": "<solution-root>\\.mcp.json",
      "description": "Solution-level MCP configuration"
    }
  }
}
